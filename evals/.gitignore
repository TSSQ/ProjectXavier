# Local secrets — never commit API keys.
.env

# Isolated Python venv (recreate with `uv venv .venv` — see README).
.venv/
__pycache__/
*.pyc

# pytest cache.
.pytest_cache/

# Compiled FM probe binary — evals/fm/probe.swift is the committed source;
# rebuild with evals/fm/build.sh.
fm/probe
fm/*.o
fm/*.swiftmodule
fm/*.swiftdoc
