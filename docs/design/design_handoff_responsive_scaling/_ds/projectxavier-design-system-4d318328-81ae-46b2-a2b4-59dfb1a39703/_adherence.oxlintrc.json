{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/core/**",
              "components/data/**",
              "components/feedback/**",
              "components/forms/**",
              "ui_kits/projectxavier-app/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Geist|Geist Mono))/i]",
        "message": "Font not provided by the design system. Available: Geist, Geist Mono."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccountRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:emoji|iconBg|dotColor|name|meta|balance|change|changeTone|onClick|key|ref|className|style|children)$/]",
        "message": "<AccountRow> doesn't accept that prop. Declared props: emoji, iconBg, dotColor, name, meta, balance, change, changeTone, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccountRow'] > JSXAttribute[name.name='changeTone'] > Literal[value!=/^(?:positive|negative|neutral)$/]",
        "message": "<AccountRow> changeTone must be one of 'positive' | 'negative' | 'neutral'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|variant|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: tone, variant."
      },
      {
        "selector": "JSXOpeningElement[name.name='Bubble'] > JSXAttribute > JSXIdentifier[name!=/^(?:from|key|ref|className|style|children)$/]",
        "message": "<Bubble> doesn't accept that prop. Declared props: from."
      },
      {
        "selector": "JSXOpeningElement[name.name='Bubble'] > JSXAttribute[name.name='from'] > Literal[value!=/^(?:ai|me)$/]",
        "message": "<Bubble> from must be one of 'ai' | 'me'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:title|variant|size|loading|iconLeft|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: title, variant, size, loading, iconLeft."
      },
      {
        "selector": "JSXOpeningElement[name.name='Card'] > JSXAttribute > JSXIdentifier[name!=/^(?:tone|padding|key|ref|className|style|children)$/]",
        "message": "<Card> doesn't accept that prop. Declared props: tone, padding."
      },
      {
        "selector": "JSXOpeningElement[name.name='Icon'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|size|color|strokeWidth|key|ref|className|style|children)$/]",
        "message": "<Icon> doesn't accept that prop. Declared props: name, size, color, strokeWidth."
      },
      {
        "selector": "JSXOpeningElement[name.name='IconButton'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|tone|size|iconColor|key|ref|className|style|children)$/]",
        "message": "<IconButton> doesn't accept that prop. Declared props: name, tone, size, iconColor."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:icon|label|sublabel|tone|trailing|onClick|key|ref|className|style|children)$/]",
        "message": "<ListRow> doesn't accept that prop. Declared props: icon, label, sublabel, tone, trailing, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='ListRow'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:default|negative)$/]",
        "message": "<ListRow> tone must be one of 'default' | 'negative'."
      },
      {
        "selector": "JSXOpeningElement[name.name='CashFlowBucket'] > JSXAttribute > JSXIdentifier[name!=/^(?:income|expense|key|ref|className|style|children)$/]",
        "message": "<CashFlowBucket> doesn't accept that prop. Declared props: income, expense."
      },
      {
        "selector": "JSXOpeningElement[name.name='Pill'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|active|key|ref|className|style|children)$/]",
        "message": "<Pill> doesn't accept that prop. Declared props: label, active."
      },
      {
        "selector": "JSXOpeningElement[name.name='SegmentedControl'] > JSXAttribute > JSXIdentifier[name!=/^(?:options|value|onChange|style|key|ref|className|style|children)$/]",
        "message": "<SegmentedControl> doesn't accept that prop. Declared props: options, value, onChange, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|value|tone|feature|key|ref|className|style|children)$/]",
        "message": "<StatTile> doesn't accept that prop. Declared props: label, value, tone, feature."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatTile'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:positive|negative)$/]",
        "message": "<StatTile> tone must be one of 'positive' | 'negative'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute > JSXIdentifier[name!=/^(?:shape|icon|trailing|multiline|inputStyle|key|ref|className|style|children)$/]",
        "message": "<TextField> doesn't accept that prop. Declared props: shape, icon, trailing, multiline, inputStyle."
      },
      {
        "selector": "JSXOpeningElement[name.name='TextField'] > JSXAttribute[name.name='shape'] > Literal[value!=/^(?:box|pill)$/]",
        "message": "<TextField> shape must be one of 'box' | 'pill'."
      },
      {
        "selector": "JSXOpeningElement[name.name='TransactionRow'] > JSXAttribute > JSXIdentifier[name!=/^(?:type|title|meta|amount|onEdit|onDelete|onClick|key|ref|className|style|children)$/]",
        "message": "<TransactionRow> doesn't accept that prop. Declared props: type, title, meta, amount, onEdit, onDelete, onClick."
      },
      {
        "selector": "JSXOpeningElement[name.name='XavierAvatar'] > JSXAttribute > JSXIdentifier[name!=/^(?:size|state|look|key|ref|className|style|children)$/]",
        "message": "<XavierAvatar> doesn't accept that prop. Declared props: size, state, look."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
