# Copy to .env (gitignored). NEVER commit real secrets.
# The LLM API key lives ONLY on the backend AI proxy, never in the app bundle.

# Public, client-safe values. Use the Supabase PUBLISHABLE key (sb_publishable_…);
# the legacy "anon" key also works. Both are low-privilege and RLS-protected.
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_PUBLISHABLE_KEY=

# AI proxy endpoint the app calls (proxy holds the real model key server-side):
EXPO_PUBLIC_AI_PROXY_URL=

# --- Backend / proxy only (do NOT expose to the app) ---
# Only the model key is a real secret. The parse function uses the auto-injected
# SUPABASE_URL + SUPABASE_ANON_KEY (low privilege) to verify the caller's JWT —
# it deliberately does NOT use the RLS-bypassing service-role key.
# ANTHROPIC_API_KEY=
