# Copy to .env (gitignored). NEVER commit real secrets.
# The LLM API key lives ONLY on the backend AI proxy, never in the app bundle.

# Public, client-safe values (Supabase anon key is RLS-protected):
EXPO_PUBLIC_SUPABASE_URL=
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# AI proxy endpoint the app calls (proxy holds the real model key server-side):
EXPO_PUBLIC_AI_PROXY_URL=

# --- Backend / proxy only (do NOT expose to the app) ---
# ANTHROPIC_API_KEY=
# SUPABASE_SERVICE_ROLE_KEY=
